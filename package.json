{
  "name": "pancake",
  "version": "0.0.0",
  "description": "Not just a pancake",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "repository": {
    "url": "https://github.com/gnehs/pancake-bot",
    "type": "git"
  },
  "main": "src/main.ts",
  "scripts": {
    "build": "pnpm run typecheck",
    "dev": "node --watch src/main.ts",
    "migrate:json": "node src/scripts/migrate-json.ts",
    "start": "node src/main.ts",
    "test": "pnpm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "author": "gnehs",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "grammy": "^1.44.0",
    "node-cron": "^4.6.0",
    "takumi-js": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
